{
  "actorSpecification": 1,
  "name": "shopsignal-mcp",
  "title": "ShopSignal — DTC Competitor Intelligence MCP",
  "description": "MCP server that gives AI agents live eyes on any DTC fashion/beauty/lifestyle brand. Catalog, prices, variants, drops, and 30-day price history — in one tool call. Works with Claude Desktop, Cursor, ChatGPT, n8n, and any MCP-compatible client.",
  "version": "0.1",
  "buildTag": "latest",
  "categories": ["MCP_SERVERS", "ECOMMERCE"],
  "input": "./input_schema.json",
  "dockerfile": "../Dockerfile",
  "minMemoryMbytes": 256,
  "maxMemoryMbytes": 2048,
  "usesStandbyMode": true,
  "webServerSchema": "./standby_schema.json",
  "webServerMcpPath": "/mcp",
  "meta": {
    "templateId": "ts-mcp-proxy"
  },
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "title": "Store snapshot results",
      "views": {
        "products": {
          "title": "Products",
          "transformation": {
            "fields": ["store_name", "scraped_at", "products"]
          },
          "display": {
            "component": "table",
            "properties": {
              "store_name": { "label": "Store" },
              "scraped_at": { "label": "Snapshot at" },
              "products": { "label": "Products", "format": "array" }
            }
          }
        }
      }
    }
  }
}
