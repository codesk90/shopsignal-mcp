# Copy to .env (which is gitignored) and fill in.
# .env is loaded automatically by `npm run smoke|healthcheck|verify-proxy`.

# Apify Personal API token. Get from:
#   https://console.apify.com/settings/integrations
# Required for SDK-based proxy access (Actor.createProxyConfiguration).
APIFY_TOKEN=

# Apify proxy password. Get from:
#   https://console.apify.com/proxy/groups
# Faster path than APIFY_TOKEN — skips an SDK round-trip. Either is sufficient.
APIFY_PROXY_PASSWORD=

# Optional: set to "1" to log detection stages (challenge detection, proxy
# retry trigger, signals matched, final classification) to stderr.
SHOPSIGNAL_VERBOSE=0
